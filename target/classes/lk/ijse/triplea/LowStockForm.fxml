<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" style="-fx-background-color: #FFF8E7;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.triplea.controllers.LowStockController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
            <children>

                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="⚠️ Low Stock Alert" textFill="#d85945">
                            <font><Font name="System Bold" size="24.0" /></font>
                            <effect><DropShadow color="#0000001a" offsetY="2.0" /></effect>
                        </Label>
                        <Label text="Items to Restock" textFill="#8d6e63">
                            <font><Font name="System Italic" size="14.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <TableView fx:id="tblLowStock" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #D85945; -fx-border-radius: 12; -fx-border-width: 1.5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="300.0" text="Item Name" />
                        <TableColumn fx:id="colQty" prefWidth="120.0" style="-fx-alignment: CENTER; -fx-text-fill: red; -fx-font-weight: bold;" text="Qty Left" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <effect><DropShadow color="#00000014" radius="5.0" /></effect>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>