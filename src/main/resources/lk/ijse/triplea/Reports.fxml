<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="600.0" prefWidth="760.0" style="-fx-background-color: #FFF8E7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.triplea.controllers.ReportsController">
    <children>
        <Button layoutX="35.0" layoutY="24.0" mnemonicParsing="false" onAction="#btnBackOnAction" prefHeight="38.0" prefWidth="156.0" style="-fx-background-color: white; -fx-text-fill: #D85945; -fx-border-color: #D85945; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="&lt; Back to Dashboard" />

        <VBox alignment="CENTER" layoutY="55.0" prefHeight="178.0" prefWidth="760.0" spacing="12.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <ImageView fitHeight="93.0" fitWidth="79.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/report%20(1).png" />
               </image>
                </ImageView>
                <Label graphicTextGap="0.0" prefHeight="54.0" prefWidth="351.0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #4E342E;" text="Report Management" />
                <Line endX="200.0" startX="-21.136474609375" startY="-0.43560275435447693" stroke="#D85945" strokeWidth="2.5" />
            </children>
        </VBox>

        <HBox alignment="CENTER" layoutY="260.0" spacing="60.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>

                <VBox fx:id="paneItemReport" alignment="CENTER" onMouseClicked="#btnItemReportOnAction" prefHeight="280.0" prefWidth="260.0" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 35; -fx-border-color: #D85945; -fx-border-radius: 35; -fx-effect: dropshadow(three-pass-box, rgba(216,89,69,0.12), 20, 0, 0, 8); -fx-cursor: hand;">
                    <children>
                        <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #D85945;" text="Item Report" />
                        <Label alignment="CENTER" prefWidth="180.0" style="-fx-text-fill: #8D6E63; -fx-font-size: 13;" text="Check inventory stock levels and unit prices." textAlignment="CENTER" wrapText="true" />
                        <Label style="-fx-background-color: #D85945; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 40 10 40; -fx-background-radius: 15;" text="VIEW" />
                    </children>
                </VBox>

                <VBox fx:id="paneOrderReport" alignment="CENTER" onMouseClicked="#btnOrderReportOnAction" prefHeight="280.0" prefWidth="260.0" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 35; -fx-border-color: #D85945; -fx-border-radius: 35; -fx-effect: dropshadow(three-pass-box, rgba(216,89,69,0.12), 20, 0, 0, 8); -fx-cursor: hand;">
                    <children>
                        <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #D85945;" text="Sales Report" />
                        <Label alignment="CENTER" prefWidth="180.0" style="-fx-text-fill: #8D6E63; -fx-font-size: 13;" text="View sales history " textAlignment="CENTER" wrapText="true" />
                        <Label style="-fx-background-color: #D85945; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 40 10 40; -fx-background-radius: 15;" text="VIEW" />
                    </children>
                </VBox>

            </children>
        </HBox>

        <VBox alignment="CENTER" layoutY="565.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label style="-fx-text-fill: #8D6E63; -fx-font-weight: bold; -fx-font-style: italic; -fx-font-size: 11; -fx-opacity: 0.8;" text="TRIPLE A • PROFESSIONAL BAKING SOLUTIONS" />
            </children>
        </VBox>
    </children>
</AnchorPane>
