<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #FFF8E7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.triplea.controllers.SupplierItemController">
    <children>
        <Button layoutX="30.0" layoutY="30.0" onAction="#btnBackOnAction" prefHeight="30.0" prefWidth="160.0" style="-fx-background-color: #5d4037; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;" text="← Back to Dashboard">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

        <VBox alignment="TOP_CENTER" layoutX="50.0" layoutY="80.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="80.0">
            <children>
                <Label text="Supplier Items Management" textFill="#d85945" underline="true">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #D85945; -fx-border-radius: 10; -fx-border-width: 0.5;">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Supplier ID:" textFill="#5d4037">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtSupplierId" onAction="#txtSupplierIdOnAction" prefWidth="120.0" style="-fx-background-color: #EEE; -fx-border-color: #AAA; -fx-border-radius: 5; -fx-background-radius: 5;" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Select Item:" textFill="#5d4037">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="cmbItems" maxWidth="1.7976931348623157E308" promptText="Choose an Item..." style="-fx-border-color: #D85945; -fx-background-radius: 5; -fx-border-radius: 5; -fx-background-color: white;" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Supply Cost (Rs):" textFill="#5d4037">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtCost" prefWidth="120.0" style="-fx-border-color: #D85945; -fx-border-radius: 5; -fx-background-radius: 5;" />
                            </children>
                        </VBox>

                        <Button onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #D85945; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Save Item Cost">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                            <effect>
                                <DropShadow color="#00000033" offsetY="2.0" />
                            </effect>
                            <HBox.margin>
                                <Insets top="22.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </HBox>

                <TableView fx:id="tblSupplierItems" prefHeight="400.0" prefWidth="800.0" style="-fx-background-color: white; -fx-border-color: #D85945; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSupId" prefWidth="100.0" text="Supplier ID" />
                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="Item Name" />
                        <TableColumn fx:id="colCost" prefWidth="150.0" text="Supply Cost (Rs)" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
      <ImageView fitHeight="82.0" fitWidth="128.0" layoutX="390.0" layoutY="5.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/product.png" />
         </image>
      </ImageView>
    </children>
</AnchorPane>
