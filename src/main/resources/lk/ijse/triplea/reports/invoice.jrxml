<jasperReport name="TripleA_Professional_Invoice" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="4eedbb89-b4f6-4469-9ab6-f642a1688cf7">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MYSQL-TRIPLEA"/>
	<parameter name="OrderID" class="java.lang.String"/>
	<parameter name="CashReceived" class="java.lang.Double"/>
	<query language="sql"><![CDATA[SELECT 
			i.name AS ItemName,
			od.qty AS Qty,
			od.unit_price AS UnitPrice,
			(od.qty * od.unit_price) AS Total
		FROM order_details od
		INNER JOIN item i ON od.item_id = i.id
		WHERE od.order_id = $P{OrderID}]]></query>
	<field name="ItemName" class="java.lang.String"/>
	<field name="Qty" class="java.lang.Integer"/>
	<field name="UnitPrice" class="java.lang.Double"/>
	<field name="Total" class="java.lang.Double"/>
	<variable name="NetTotal" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{Total}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
