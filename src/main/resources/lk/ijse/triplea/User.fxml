                            <VBox.margin><Insets left="25.0" right="25.0" /></VBox.margin>
                        </Button>
                        <Button fx:id="btnSuppliers" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnSupplierManagementOnAction" prefHeight="55.0" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-cursor: hand;" text="🚚   Supplier Management" textFill="WHITE">
