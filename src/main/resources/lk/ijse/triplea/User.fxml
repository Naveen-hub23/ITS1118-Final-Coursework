                        <Button fx:id="btnUserManagement" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnUserManagementOnAction" prefHeight="55.0" style="-fx-background-color: #c44e3b; -fx-background-radius: 12; -fx-cursor: hand;" text="👤   User Management" textFill="WHITE">
