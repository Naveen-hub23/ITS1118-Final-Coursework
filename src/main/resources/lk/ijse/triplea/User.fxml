                            <VBox.margin><Insets left="25.0" right="25.0" /></VBox.margin>
                        </Button>
                        <Button fx:id="btnItems" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnItemManagementOnAction" prefHeight="55.0" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-cursor: hand;" text="📦   Item Management" textFill="WHITE">
                            <font><Font name="System Bold" size="15.0" /></font>
