                        </Button>
                        <Button fx:id="btnBilling" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnBillingOnAction" prefHeight="55.0" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-cursor: hand;" text="💳   Billing" textFill="WHITE">
                            <font><Font name="System Bold" size="15.0" /></font>
                            <padding><Insets left="30.0" /></padding>
                            <VBox.margin><Insets left="25.0" right="25.0" /></VBox.margin>
                        </Button>
                        <Button fx:id="btnReports" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnReportsOnAction" prefHeight="55.0" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-cursor: hand;" text="📊   Reports" textFill="WHITE">
