                                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                    <children>
                                        <Button fx:id="btnReset" mnemonicParsing="false" onAction="#handleResetFields" prefHeight="38.0" prefWidth="100.0" style="-fx-background-color: #8d6e63; -fx-text-fill: white; -fx-background-radius: 12; -fx-cursor: hand;" text="Reset" />
                                        <Button fx:id="btnDeleteUser" mnemonicParsing="false" onAction="#handleDeleteUser" prefHeight="38.0" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 12; -fx-cursor: hand;" text="Delete" />
                                        <Button fx:id="btnUpdateUser" mnemonicParsing="false" onAction="#handleUpdateUser" prefHeight="38.0" prefWidth="100.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-background-radius: 12; -fx-cursor: hand;" text="Update" />
                                        <Button fx:id="btnSaveUser" mnemonicParsing="false" onAction="#saveUser" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="Save User" />
