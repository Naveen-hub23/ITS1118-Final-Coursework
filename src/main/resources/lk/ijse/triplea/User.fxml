                        <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25;">
                            <effect><DropShadow color="#0000001a" radius="10.0" /></effect>
                            <children>
                                <HBox spacing="30.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Username" textFill="#8d6e63"><font><Font name="System Bold" size="14.0" /></font></Label>
