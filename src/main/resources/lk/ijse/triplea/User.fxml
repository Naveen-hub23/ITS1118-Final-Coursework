                        <Button fx:id="btnSupplierItems" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnSupplierItemsOnAction" prefHeight="55.0" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-cursor: hand;" text="🏗   Supplier Items" textFill="WHITE">
