                    <padding><Insets bottom="10.0" top="20.0" /></padding>
                </VBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnDashboardOnAction" prefHeight="55.0" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-cursor: hand;" text="🏠   Dashboard" textFill="WHITE">
