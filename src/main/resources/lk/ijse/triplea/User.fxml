                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Phone Number" textFill="#8d6e63"><font><Font name="System Bold" size="14.0" /></font></Label>
                                                <TextField fx:id="phoneField" prefHeight="40.0" style="-fx-background-radius: 10; -fx-border-color: #D85945; -fx-border-radius: 10;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="30.0">
                                    <children>

                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Password" textFill="#8d6e63"><font><Font name="System Bold" size="14.0" /></font></Label>
                                                <HBox>
                                                    <children>
                                                        <StackPane HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <PasswordField fx:id="passwordField" prefHeight="40.0" style="-fx-background-radius: 10 0 0 10; -fx-border-color: #D85945; -fx-border-radius: 10 0 0 10; -fx-border-width: 1 0 1 1;" />
                                                                <TextField fx:id="passwordTextField" managed="false" prefHeight="40.0" style="-fx-background-radius: 10 0 0 10; -fx-border-color: #D85945; -fx-border-radius: 10 0 0 10; -fx-border-width: 1 0 1 1;" visible="false" />
                                                            </children>
                                                        </StackPane>
                                                        <Button fx:id="btnTogglePassword" mnemonicParsing="false" onAction="#togglePasswordVisible" prefHeight="40.0" prefWidth="45.0" style="-fx-background-color: white; -fx-border-color: #D85945; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0; -fx-cursor: hand;" text="👁" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Role" textFill="#8d6e63"><font><Font name="System Bold" size="14.0" /></font></Label>
                                                <ComboBox fx:id="roleComboBox" maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Select Role" style="-fx-background-radius: 10; -fx-border-color: #D85945; -fx-border-radius: 10; -fx-background-color: white;">
                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                            <String fx:value="Owner" />
                                                            <String fx:value="Assistant" />
                                                            <String fx:value="Cashier" />
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Status" textFill="#8d6e63"><font><Font name="System Bold" size="14.0" /></font></Label>
                                                <ComboBox fx:id="statusComboBox" maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Select Status" style="-fx-background-radius: 10; -fx-border-color: #D85945; -fx-border-radius: 10; -fx-background-color: white;">
                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                            <String fx:value="ACTIVE" />
                                                            <String fx:value="DEACTIVE" />
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>
                                            </children>
                                        </VBox>

                                    </children>
