<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.triplea.controllers.UserController">

    <left>
        <VBox prefHeight="700.0" prefWidth="280.0" style="-fx-background-color: #D85945; -fx-background-radius: 0 30 0 0;" BorderPane.alignment="CENTER">
