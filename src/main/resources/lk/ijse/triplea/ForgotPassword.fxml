<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="350.0" style="-fx-background-color: #FFF8E7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.triplea.controllers.ForgotPasswordController">
    <children>
        <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Password Reset" textFill="#d85945">
                    <font><Font name="System Bold" size="20.0" /></font>
                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                </Label>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Username" textFill="#5d4037"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <TextField fx:id="txtUsername" onAction="#txtUsernameOnAction" style="-fx-border-color: #D85945; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Security Question" textFill="#5d4037"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <TextField fx:id="txtQuestion" editable="false" style="-fx-background-color: #EEE; -fx-border-color: #AAA; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Answer" textFill="#5d4037"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <TextField fx:id="txtAnswer" style="-fx-border-color: #D85945; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="New Password" textFill="#5d4037"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <TextField fx:id="txtNewPassword" style="-fx-border-color: #D85945; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <Button onAction="#btnResetOnAction" prefHeight="35.0" prefWidth="290.0" style="-fx-background-color: #D85945; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Reset Password">
                    <font><Font name="System Bold" size="14.0" /></font>
                    <effect><DropShadow color="#00000033" offsetY="2.0" /></effect>
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>
